{
  "name": "lunchmoney-mcp-server",
  "version": "0.4.4",
  "description": "Self-hostable remote MCP server for Lunch Money with built-in OAuth 2.1 — works with claude.ai custom connectors (mobile/web/desktop).",
  "private": true,
  "type": "module",
  "main": "server.mjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Squixx/lunchmoney-mcp-server-oauth.git"
  },
  "engines": {
    "node": ">=22.22.0",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85",
  "scripts": {
    "start": "node server.mjs",
    "audit": "pnpm audit --audit-level=moderate",
    "test": "node smoke-test.mjs"
  },
  "dependencies": {
    "@akutishevsky/lunchmoney-mcp": "2.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1"
  }
}

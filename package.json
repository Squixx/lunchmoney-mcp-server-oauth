{
  "name": "lunchmoney-mcp-server",
  "version": "0.4.1",
  "description": "Self-hostable remote MCP server for Lunch Money with built-in OAuth 2.1 — works with claude.ai custom connectors (mobile/web/desktop).",
  "private": true,
  "type": "module",
  "main": "server.mjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Squixx/lunchmoney-mcp-server-oauth.git"
  },
  "engines": {
    "node": ">=22.22.0",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "scripts": {
    "start": "node server.mjs",
    "audit": "pnpm audit --audit-level=moderate",
    "test": "node smoke-test.mjs"
  },
  "dependencies": {
    "@akutishevsky/lunchmoney-mcp": "2.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1"
  }
